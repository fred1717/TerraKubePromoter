# =============================================================================
# Docker build context exclusions
# =============================================================================
# Files and directories excluded from the Docker build context.
# Smaller context means faster builds, smaller images, and reduced attack
# surface in production.
#
# Reference: https://docs.docker.com/build/concepts/context/#dockerignore-files
# =============================================================================

# -----------------------------------------------------------------------------
# Python artefacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Virtual environment
# -----------------------------------------------------------------------------
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Development and test files (not shipped to production)
# -----------------------------------------------------------------------------
tests/
requirements-dev.txt
pyproject.toml

# -----------------------------------------------------------------------------
# IDE and editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Git metadata
# -----------------------------------------------------------------------------
.git/
.gitignore

# -----------------------------------------------------------------------------
# Docker files themselves (not needed inside the image)
# -----------------------------------------------------------------------------
Dockerfile
.dockerignore

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
README.md
